<div id="main-bar" class="main-bar__container">
  <% if content_for?(:focus_mode) %>
    <div class="main-bar main-bar--focus-mode-back-button">
      <%= render partial: "layouts/decidim/header/focus_mode_back_button" if content_for(:focus_mode_return_path) %>
    </div>
  <% else %>
    <div class="main-bar">
      <div class="main-bar__logo">
        <div class="main-bar__logo-desktop">
          <div style="display: flex; align-items: center; gap: 16px; flex-wrap: nowrap;">
            <%= render partial: "layouts/decidim/logo", locals: { organization: current_organization } %>
            <div class="main-bar__secondary-logo" style="flex-shrink: 0; display: flex; align-items: center;">
              <%= render partial: "layouts/decidim/secondary_logo" %>
            </div>
          </div>
        </div>
        <div class="main-bar__logo-mobile">
          <div style="display: flex; align-items: center; gap: 12px; flex-wrap: nowrap;">
            <%= render partial: "layouts/decidim/logo_mobile", locals: { organization: current_organization } %>
            <div class="main-bar__secondary-logo-mobile" style="flex-shrink: 0; display: flex; align-items: center;">
              <%= render partial: "layouts/decidim/secondary_logo" %>
            </div>
          </div>
        </div>
      </div>
      <% if current_user&.ephemeral? %>
        <%= render partial: "layouts/decidim/header/close_ephemeral_session" %>
      <% else %>
        <div role="search" class="main-bar__search">
          <%= render partial: "layouts/decidim/header/main_search" %>
        </div>
        <nav role="navigation" class="main-bar__links-desktop">
          <%= render partial: "layouts/decidim/header/main_links_desktop" %>
        </nav>
        <div class="main-bar__menu-mobile">
          <%= render partial: "layouts/decidim/header/main_menu_mobile" %>
        </div>
        <%= render partial: "layouts/decidim/header/main_links_mobile_account" if current_user %>
      <% end %>
    </div>
  <% end %>
</div>
